{
  "manifest_version": 3,
  "name": "Boost for Letterboxd",
  "version": "1.2",
  "description": "Boost for Letterboxd - Boost Letterboxd results to the top of Google and adds a right-click Search on Letterboxd option.",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": ["contextMenus", "storage"],
  "action": {
    "default_title": "Boost for Letterboxd",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["icon48.png"],
      "matches": [
        "https://www.google.com/*",
        "https://www.google.fr/*",
        "https://www.google.co.uk/*",
        "https://www.google.ca/*",
        "https://www.google.be/*",
        "https://www.google.ch/*",
        "https://www.google.de/*",
        "https://www.google.es/*",
        "https://www.google.it/*",
        "https://www.google.com.au/*",
        "https://www.google.co.in/*",
        "https://www.google.com.br/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://www.google.fr/search*",
        "https://www.google.co.uk/search*",
        "https://www.google.ca/search*",
        "https://www.google.be/search*",
        "https://www.google.ch/search*",
        "https://www.google.de/search*",
        "https://www.google.es/search*",
        "https://www.google.it/search*",
        "https://www.google.com.au/search*",
        "https://www.google.co.in/search*",
        "https://www.google.com.br/search*"
      ],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_end"
    }
  ]
}
